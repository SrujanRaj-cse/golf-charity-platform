PORT=5000
NODE_ENV=development

# Mongo
MONGODB_URI=mongodb://127.0.0.1:27017/golf_charity_platform

# Auth
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Optional: bootstrap admin by email (comma-separated)
ADMIN_EMAIL=

# Frontend origin used for Stripe redirect URLs (fallbacks are fine)
CLIENT_BASE_URL=http://localhost:5173

# Stripe (optional for local dev; can be disabled via STRIPE_ENABLED=false)
STRIPE_ENABLED=true
STRIPE_SECRET_KEY=replace-me
STRIPE_WEBHOOK_SECRET=replace-me
STRIPE_PRICE_MONTHLY_ID=replace-me
STRIPE_PRICE_YEARLY_ID=replace-me

# Prize pool math (reasonable defaults; can be tuned)
PRIZE_POOL_PERCENT=0.2

# Plan prices in cents for prize math (Stripe amounts can differ; this keeps payout math stable)
PLAN_MONTHLY_PRICE_CENTS=2500
PLAN_YEARLY_PRICE_CENTS=25000

